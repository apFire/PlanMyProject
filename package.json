{
  "name": "plan-my-project",
  "displayName": "Plan My Project",
  "description": "Unified project planning AI expansion and task execution.",
  "icon": "media/marketplace-icon.png",
  "version": "0.1.0",
  "publisher": "aypande",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/apFire/PlanMyProject.git"
  },
  "homepage": "https://github.com/apFire/PlanMyProject#readme",
  "bugs": {
    "url": "https://github.com/apFire/PlanMyProject/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "keywords": [
    "project planning",
    "task management",
    "copilot",
    "ai",
    "markdown",
    "productivity"
  ],
  "categories": [
    "Other"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false,
      "description": "PlanMyProject reads and writes workspace files to maintain plans and apply implementation changes."
    }
  },
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:planmyproject.openPlan",
    "onCommand:planmyproject.planTask",
    "onCommand:planmyproject.addTask",
    "onCommand:planmyproject.addRootTask",
    "onCommand:planmyproject.loadRequirementsFile",
    "onCommand:planmyproject.drillDown",
    "onCommand:planmyproject.implementTask",
    "onCommand:planmyproject.deleteTask",
    "onCommand:planmyproject.rebuildQueue",
    "onView:planmyproject.tree"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "planmyproject.openPlan",
        "title": "PlanMyProject: Open Plan"
      },
      {
        "command": "planmyproject.planTask",
        "title": "PlanMyProject: Plan Task (One Level)",
        "icon": {
          "light": "media/plan.svg",
          "dark": "media/plan.svg"
        }
      },
      {
        "command": "planmyproject.addTask",
        "title": "PlanMyProject: Add Task",
        "icon": {
          "light": "media/add.svg",
          "dark": "media/add.svg"
        }
      },
      {
        "command": "planmyproject.addRootTask",
        "title": "PlanMyProject: Add Root Task"
      },
      {
        "command": "planmyproject.loadRequirementsFile",
        "title": "PlanMyProject: Load Requirements File"
      },
      {
        "command": "planmyproject.drillDown",
        "title": "PlanMyProject: Drill Down Task",
        "icon": {
          "light": "media/drill.svg",
          "dark": "media/drill.svg"
        }
      },
      {
        "command": "planmyproject.implementTask",
        "title": "PlanMyProject: Implement Task (Copilot)",
        "icon": {
          "light": "media/execute.svg",
          "dark": "media/execute.svg"
        }
      },
      {
        "command": "planmyproject.deleteTask",
        "title": "PlanMyProject: Delete Task",
        "icon": {
          "light": "media/delete.svg",
          "dark": "media/delete.svg"
        }
      },
      {
        "command": "planmyproject.rebuildQueue",
        "title": "PlanMyProject: Rebuild Execution Queue",
        "icon": {
          "light": "media/queue.svg",
          "dark": "media/queue.svg"
        }
      },
      {
        "command": "planmyproject.refreshTree",
        "title": "PlanMyProject: Refresh Tree",
        "icon": {
          "light": "media/refresh.svg",
          "dark": "media/refresh.svg"
        }
      }
    ],
    "keybindings": [
      {
        "command": "planmyproject.planTask",
        "key": "alt+p",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "planmyproject",
          "title": "PlanMyProject",
          "icon": "media/activity.svg"
        }
      ]
    },
    "views": {
      "planmyproject": [
        {
          "id": "planmyproject.tree",
          "name": "Implementation Tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "planmyproject.tree",
        "contents": "No tasks found yet.\n\nUse this when requirements already exist in a root `.md` file.\nConsider: clearer requirement lines produce better root tasks.\n[Load Requirements File](command:planmyproject.loadRequirementsFile)\n\nUse this when starting from scratch or adding one objective manually.\nConsider: keep each root task scoped, actionable, and implementation-ready.\n[Add Root Task](command:planmyproject.addRootTask)",
        "when": "planmyproject.treeEmpty"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "planmyproject.addTask",
          "when": "view == planmyproject.tree",
          "group": "navigation@1"
        },
        {
          "command": "planmyproject.refreshTree",
          "when": "view == planmyproject.tree",
          "group": "navigation@2"
        },
        {
          "command": "planmyproject.rebuildQueue",
          "when": "view == planmyproject.tree",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "planmyproject.addTask",
          "when": "view == planmyproject.tree",
          "group": "inline@1"
        },
        {
          "command": "planmyproject.planTask",
          "when": "view == planmyproject.tree",
          "group": "inline@2"
        },
        {
          "command": "planmyproject.implementTask",
          "when": "view == planmyproject.tree",
          "group": "inline@3"
        },
        {
          "command": "planmyproject.drillDown",
          "when": "view == planmyproject.tree",
          "group": "inline@4"
        },
        {
          "command": "planmyproject.deleteTask",
          "when": "view == planmyproject.tree",
          "group": "inline@5"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:build": "tsc -p ./tsconfig.test.json",
    "test": "npm run test:build && node --test out-test/test/**/*.test.js",
    "verify": "npm run compile && npm test",
    "package": "npx @vscode/vsce package --no-yarn",
    "publish:vsce": "npx @vscode/vsce publish --no-yarn"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.2"
  }
}
